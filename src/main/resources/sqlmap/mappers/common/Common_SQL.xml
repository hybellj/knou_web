<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="CommonSQL">

	<!-- Page Prefix -->
	<sql id="pagePrefix">
		SELECT * FROM (
    </sql>

	<!-- Page Subfix -->
	<sql id="pageSubfix">
		<!-- LIMIT #{firstIndex}, #{listScale} -->
		) A
		WHERE 1=1
		  <!-- AND ROWNUM <![CDATA[>]]> #{firstIndex} AND ROWNUM <![CDATA[<=]]> #{listScale} -->
		  AND LINE_NO BETWEEN #{firstIndex} +1 AND #{firstIndex} + #{listScale}
    </sql>
    
</mapper>
