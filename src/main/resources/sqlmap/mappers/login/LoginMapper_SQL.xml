<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="knou.lms.login.dao.LoginDAO">

	<select id="selectOrgList" resultType="loginVO">
		SELECT ORG_ID
		     , ORGNM
		  FROM TB_LMS_ORG
		 WHERE USEYN  = 'Y'
	</select>
	
</mapper>