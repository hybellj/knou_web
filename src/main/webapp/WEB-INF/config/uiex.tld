	<!-- 페이징 표시 -->
	<tag>
		<name>paging</name>
		<tag-class>knou.framework.taglib.PagingTag</tag-class>
		<body-content>empty</body-content>
		<attribute>
			<name>pageInfo</name>
			<required>true</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>pageFunc</name>
			<required>true</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>showTotRecord</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>showCurrentPage</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
	</tag>


	<!-- 파일 다운로드 -->
	<tag>
		<name>filedownload</name>
		<tag-class>knou.framework.taglib.FileDownloadTag</tag-class>
		<body-content>empty</body-content>
		<attribute>
			<name>fileList</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>atflVO</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
	</tag>


	<!-- 코드명 출력 -->
	<tag>
		<name>codeName</name>
		<tag-class>knou.framework.taglib.CodeNameTag</tag-class>
		<body-content>empty</body-content>
		<attribute>
			<name>upCd</name>
			<required>true</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>cd</name>
			<required>true</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>orgId</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
	</tag>


	<!-- 코드 selectbox 생성 -->
	<tag>
		<name>codeSelectBox</name>
		<tag-class>knou.framework.taglib.CodeSelectTag</tag-class>
		<body-content>empty</body-content>
		<attribute>
			<name>name</name>
			<required>true</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>id</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>upCd</name>
			<required>true</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>selectedVal</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onchange</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>title</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>selectMsg</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>style</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>styleClass</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>required</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>multiple</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
	</tag>


	<!-- DEXT 파일 업로더 -->
	<tag>
		<name>dextuploader</name>
		<tag-class>knou.framework.taglib.DextUploaderTag</tag-class>
		<body-content>empty</body-content>
		<attribute>
			<name>id</name>
			<required>true</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>path</name>
			<required>true</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>url</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>limitCount</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>limitSize</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>oneLimitSize</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>listSize</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>allowedTypes</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>notAllowedTypes</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>finishFunc</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>fileList</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>bigSize</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>lang</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>uiMode</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
	</tag>


	<!-- 리스트 스케일 태그 -->
	<tag>
		<name>listScale</name>
		<tag-class>knou.framework.taglib.ListScaleTag</tag-class>
		<body-content>empty</body-content>
		<attribute>
			<name>id</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>value</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>func</name>
			<required>true</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>styleClass</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
	</tag>


	<!-- HTML 에디터 태그 -->
	<tag>
		<name>htmlEditor</name>
		<tag-class>knou.framework.taglib.HtmlEditorTag</tag-class>
		<body-content>empty</body-content>
		<attribute>
			<name>id</name>
			<required>true</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>name</name>
			<required>true</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>value</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>uploadPath</name>
			<required>true</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>videoUpload</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>uploadMaxSize</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>width</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>height</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>required</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
	</tag>

	<!-- 네비게이션바 표시 태그 -->
	<tag>
		<name>navibar</name>
		<tag-class>knou.framework.taglib.NavibarTag</tag-class>
		<body-content>empty</body-content>
		<attribute>
			<name>type</name>
			<required>true</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
	</tag>


	<!--
	JSTL 공통 함수 정의
	-->

	<!-- 암호화 파라메터값 가져오기 -->
	<function>
		<name>getParamValue</name>
		<function-class>knou.framework.taglib.CommFunctionTag</function-class>
		<function-signature>java.lang.String getParamValue(java.lang.String)</function-signature>
	</function>

	<!-- 사용자 이름 마스킹 -->
	<function>
		<name>maskUserNm</name>
		<function-class>knou.framework.taglib.CommFunctionTag</function-class>
		<function-signature>java.lang.String maskUserNm(java.lang.String)</function-signature>
	</function>

	<!-- 전화번호 마스킹 -->
	<function>
		<name>maskPhoneNo</name>
		<function-class>knou.framework.taglib.CommFunctionTag</function-class>
		<function-signature>java.lang.String maskPhoneNo(java.lang.String)</function-signature>
	</function>

	<!-- 이메일 마스킹 -->
	<function>
		<name>maskEmail</name>
		<function-class>knou.framework.taglib.CommFunctionTag</function-class>
		<function-signature>java.lang.String maskEmail(java.lang.String)</function-signature>
	</function>

	<!-- 주소 마스킹 -->
	<function>
		<name>maskAddress</name>
		<function-class>knou.framework.taglib.CommFunctionTag</function-class>
		<function-signature>java.lang.String maskAddress(java.lang.String)</function-signature>
	</function>

	<!-- 주민번호 마스킹 -->
	<function>
		<name>maskJuminNo</name>
		<function-class>knou.framework.taglib.CommFunctionTag</function-class>
		<function-signature>java.lang.String maskJuminNo(java.lang.String)</function-signature>
	</function>

	<!-- IP Address 마스킹 -->
	<function>
		<name>maskIpAddress</name>
		<function-class>knou.framework.taglib.CommFunctionTag</function-class>
		<function-signature>java.lang.String maskIpAddress(java.lang.String)</function-signature>
	</function>


</taglib>
