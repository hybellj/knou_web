	<!-- 날짜/시간을 지정된 포맷으로 출력 -->
	<tag>
		<name>formatDate</name>
		<tag-class>knou.framework.taglib.FormatDateTag</tag-class>
		<body-content>empty</body-content>
		<attribute>
			<name>value</name>
			<required>true</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>type</name>
			<required>true</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
	</tag>

