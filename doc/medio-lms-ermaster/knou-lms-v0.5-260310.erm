			<physical_name>V_MSG_NOTI_UNIFIED</physical_name>
			<logical_name>V_MSG_NOTI_UNIFIED</logical_name>
			<description></description>
			<sql>SELECT&#x0D;&#x0A;    S.MSG_SHRTNT_SNDNG_ID AS NOTI_ID,&#x0D;&#x0A;    &apos;SHRTNT&apos;               AS CHNL_CD,&#x0D;&#x0A;    S.MSG_ID,&#x0D;&#x0A;    SO.SBJCTNM,&#x0D;&#x0A;    S.SNDNG_TTL            AS NOTI_TTL,&#x0D;&#x0A;    S.SNDNG_CTS            AS NOTI_CTS,&#x0D;&#x0A;    S.SNDNGR_ID,&#x0D;&#x0A;    S.SNDNGNM,&#x0D;&#x0A;    S.RCVR_ID,&#x0D;&#x0A;    S.RCVRNM,&#x0D;&#x0A;    S.SNDNG_DTTM,&#x0D;&#x0A;    TO_CHAR(TO_DATE(S.SNDNG_DTTM, &apos;YYYYMMDDHH24MISS&apos;), &apos;YYYY.MM.DD&apos;) AS SNDNG_DTTM_FMT,&#x0D;&#x0A;    S.READ_DTTM,&#x0D;&#x0A;    CASE WHEN S.READ_DTTM IS NULL THEN &apos;N&apos; ELSE &apos;Y&apos; END AS READ_YN&#x0D;&#x0A;FROM DEV_LMS.TB_LMS_MSG_SHRTNT_SNDNG S&#x0D;&#x0A;         LEFT JOIN DEV_LMS.TB_LMS_MSG M ON S.MSG_ID = M.MSG_ID&#x0D;&#x0A;         LEFT JOIN DEV_LMS.TB_LMS_SBJCT_OFRNG SO ON M.SBJCT_OFRNG_ID = SO.SBJCT_OFRNG_ID&#x0D;&#x0A;WHERE S.RCVR_DELYN = &apos;N&apos;&#x0D;&#x0A;UNION ALL&#x0D;&#x0A;-- 모바일 (PUSH/SMS/ALIMTALK)&#x0D;&#x0A;SELECT&#x0D;&#x0A;    B.MSG_MBL_SNDNG_ID,&#x0D;&#x0A;    B.MBL_SNDNG_TYCD,&#x0D;&#x0A;    B.MSG_ID,&#x0D;&#x0A;    SO.SBJCTNM,&#x0D;&#x0A;    B.SNDNG_TTL,&#x0D;&#x0A;    B.SNDNG_CTS,&#x0D;&#x0A;    B.SNDNGR_ID,&#x0D;&#x0A;    B.SNDNGNM,&#x0D;&#x0A;    B.RCVR_ID,&#x0D;&#x0A;    B.RCVRNM,&#x0D;&#x0A;    B.SNDNG_DTTM,&#x0D;&#x0A;    TO_CHAR(TO_DATE(B.SNDNG_DTTM, &apos;YYYYMMDDHH24MISS&apos;), &apos;YYYY.MM.DD&apos;) AS SNDNG_DTTM_FMT,&#x0D;&#x0A;    B.READ_DTTM,&#x0D;&#x0A;    CASE WHEN B.READ_DTTM IS NULL THEN &apos;N&apos; ELSE &apos;Y&apos; END AS READ_YN&#x0D;&#x0A;FROM DEV_LMS.TB_LMS_MSG_MBL_SNDNG B&#x0D;&#x0A;         LEFT JOIN DEV_LMS.TB_LMS_MSG M ON B.MSG_ID = M.MSG_ID&#x0D;&#x0A;         LEFT JOIN DEV_LMS.TB_LMS_SBJCT_OFRNG SO ON M.SBJCT_OFRNG_ID = SO.SBJCT_OFRNG_ID</sql>
